<?xml version="1.0" encoding="utf-8"?>
<BindingDefinition xmlns="http://www.br-automation.com/iat2014/binding/runtime/v1">
  <Content id="top">
    <Binding mode="twoWay">
			<Source xsi:type="opcUa" refId="::AsGlobalPV:bStart" attribute="value" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" />
			<Target xsi:type="brease" refId="top_ToggleTimer_Btn" attribute="value" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" />
		</Binding><Binding mode="oneWay">
			<Source xsi:type="opcUa" refId="::AsGlobalPV:bStart" attribute="editable" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" />
			<Target xsi:type="brease" refId="top_ToggleTimer_Btn" attribute="editable::value" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" />
		</Binding>
  </Content>
  <Content id="main">
    <Binding mode="oneWay">
<Source xsi:type="variable" refId="GreenColour" attribute="value" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" />
<Target xsi:type="brease" refId="main_Ellipse2" attribute="style" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" />
</Binding>
  </Content>
  <Content id="main">
    <Binding mode="twoWay">
<Source xsi:type="opcUa" refId="::AsGlobalPV:isTrapperButtonPressed" attribute="value" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" />
<Target xsi:type="brease" refId="main_Ellipse2" attribute="visible" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" />
</Binding>
  </Content>
  <Content id="main">
    <Binding mode="twoWay">
<Source xsi:type="opcUa" refId="::AsGlobalPV:isTrapperButtonNotPressed" attribute="value" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" />
<Target xsi:type="brease" refId="main_Ellipse1" attribute="visible" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" />
</Binding>
  </Content>
  <Content id="main">
    <Binding mode="twoWay">
<Source xsi:type="opcUa" refId="::AsGlobalPV:isVeldButtonNotPressed" attribute="value" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" />
<Target xsi:type="brease" refId="main_Ellipse4" attribute="visible" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" />
</Binding>
  </Content>
  <Content id="main">
    <Binding mode="twoWay">
<Source xsi:type="opcUa" refId="::AsGlobalPV:isVeldButtonPressed" attribute="value" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" />
<Target xsi:type="brease" refId="main_Ellipse3" attribute="visible" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" />
</Binding>
  </Content>
</BindingDefinition>